  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "A sudden clarity cuts through the fear. \nThe walls shift unnaturally,
    the air vibrates\u2014it\u2019s all artificial. \nThis isn\u2019t a place. It\u2019s
    a construct, a dream, a puzzle built from my own logic. \nIf this world was made
    by thought, maybe I can unmake it too."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6645c2303c995984f99d8e3c3216eaf5, type: 2}
