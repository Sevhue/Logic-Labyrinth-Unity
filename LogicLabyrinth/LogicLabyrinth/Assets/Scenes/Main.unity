  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The maze stretches endlessly before me. \nEvery path looks the same, twisting
    into itself like a cruel joke. \nI hear distant echoes\u2014footsteps, maybe
    my own. \nFear grows heavier with each turn. \nI can\u2019t tell if I\u2019m
    being hunted... or if I\u2019m chasing myself."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6645c2303c995984f99d8e3c3216eaf5, type: 2}
